# Copy to secret.yaml and apply, or:
#   GITHUB_TOKEN=... GEMINI_API_KEY=... ./deploy/scripts/apply-app-secrets.sh
apiVersion: v1
kind: Secret
metadata:
  name: unified-dashboard-secrets
  labels:
    app.kubernetes.io/name: unified-dashboard
type: Opaque
stringData:
  # Required for stable API usage (5000 core req/hr + 30 search req/min)
  GITHUB_TOKEN: ""
  # Gemini — AI mode issue complexity analysis
  GEMINI_API_KEY: ""
